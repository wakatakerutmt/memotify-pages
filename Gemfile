# Pinned to the gems used by GitHub Pages so `bundle exec jekyll serve`
# matches what GitHub builds. Source:
# https://pages.github.com/versions/
source "https://rubygems.org"

gem "github-pages", group: :jekyll_plugins
gem "jekyll-relative-links"

# Required for Ruby 3.0+ where these were removed from stdlib.
gem "webrick", "~> 1.8"
